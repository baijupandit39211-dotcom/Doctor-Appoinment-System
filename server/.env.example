NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
# Local MongoDB default for development.
# If you use MongoDB Atlas later, replace this with your Atlas connection string.
MONGODB_URI=mongodb://127.0.0.1:27017/docpulse
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=docpulse_token
